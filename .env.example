DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# Auth.js / NextAuth-ready production values. Add provider-specific keys when auth is implemented.
AUTH_SECRET="replace-with-output-from-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Optional OAuth providers for Auth.js.
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Optional private-beta access gate. When both values are set, every page/API
# except /api/health requires browser Basic Auth.
# APP_BASIC_AUTH_USER="admin"
# APP_BASIC_AUTH_PASSWORD="replace-with-a-long-random-password"
